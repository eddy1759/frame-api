# .env.example
NODE_ENV=development
PORT=8000
HOST=0.0.0.0
API_PREFIX=v1
HTTP_KEEP_ALIVE_TIMEOUT=65000
HTTP_HEADERS_TIMEOUT=66000
HTTP_REQUEST_TIMEOUT=120000
HTTP_ACCESS_LOG_ENABLED=false

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=frame_user
DB_PASSWORD=<your_db_password>
DB_NAME=frame_db
DB_SSL=false
DB_POOL_MAX=50
DB_POOL_MIN=5

REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=frame_redis_password_dev
REDIS_DB=0

JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=2592000

GOOGLE_CLIENT_ID=<your_google_client_id>
APPLE_CLIENT_ID=<your_apple_client_id>

ENCRYPTION_KEY=<32_byte_hex_string>
THROTTLE_TTL=60
THROTTLE_LIMIT=10
CORS_ORIGINS=http://localhost:3000
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=access_key
OBJECT_STORAGE_SECRET_KEY=secret_key
OBJECT_STORAGE_BUCKET=frame-assets
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_USE_SSL=false
CDN_BASE_URL=http://localhost:9000/frame-assets


