# .env.example
NODE_ENV=development
PORT=8000
HOST=0.0.0.0
API_PREFIX=api/v1
HTTP_KEEP_ALIVE_TIMEOUT=65000
HTTP_HEADERS_TIMEOUT=66000
HTTP_REQUEST_TIMEOUT=120000
HTTP_ACCESS_LOG_ENABLED=false

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=frame_user
DB_PASSWORD=<your_db_password>
DB_NAME=frame_db
DB_SSL=false
DB_POOL_MAX=50
DB_POOL_MIN=5
DB_AUTO_RUN_MIGRATIONS=true

## Optional: use a single Redis URL for hosted providers like Upstash
# REDIS_URL=rediss://default:<password>@<host>:6379
# REDIS_QUEUE_URL=
# When REDIS_URL is shared by app Redis and BullMQ, leave REDIS_QUEUE_DB unset.

REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=frame_redis_password_dev
REDIS_DB=0
REDIS_QUEUE_DB=1
REDIS_QUEUE_NAME=frame-queue

JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=2592000

GOOGLE_CLIENT_ID=<your_google_client_id>
APPLE_CLIENT_ID=<your_apple_client_id>

ENCRYPTION_KEY=<32_byte_hex_string>
THROTTLE_TTL=60
THROTTLE_LIMIT=10
CORS_ORIGINS=http://localhost:3000
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=access_key
OBJECT_STORAGE_SECRET_KEY=secret_key
OBJECT_STORAGE_BUCKET=frame-assets
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_USE_SSL=false
CDN_BASE_URL=http://localhost:9000/frame-assets
OBJECT_STORAGE_CONNECTION_TIMEOUT_MS=5000
OBJECT_STORAGE_SOCKET_TIMEOUT_MS=20000
OBJECT_STORAGE_UPLOAD_MAX_ATTEMPTS=4
OBJECT_STORAGE_UPLOAD_BASE_DELAY_MS=1000
PRESIGNED_URL_EXPIRY=3600
IMAGE_MAX_SIZE=52428800
IMAGE_DAILY_UPLOAD_LIMIT=100
IMAGE_DEFAULT_STORAGE_LIMIT=5368709120
IMAGE_SOFT_DELETE_GRACE_DAYS=30
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=3000
QUEUE_REMOVE_ON_COMPLETE_AGE=86400
QUEUE_REMOVE_ON_COMPLETE_COUNT=1000
QUEUE_REMOVE_ON_FAIL_AGE=604800
