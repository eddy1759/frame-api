{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^jsdom$": "<rootDir>/../src/test/mocks/jsdom.mock.ts",
    "^dompurify$": "<rootDir>/../src/test/mocks/dompurify.mock.ts",
    "^uuid$": "<rootDir>/../src/test/mocks/uuid.mock.ts"
  }
}
